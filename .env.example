# PostgreSQL. Locally: a local Postgres or a hosted dev branch (Neon/Supabase).
# On Vercel: set these in Project Settings → Environment Variables.

# Pooled connection (serverless runtime). For Neon, use the "-pooler" host.
DATABASE_URL="postgresql://user:password@host:5432/commitment_tracker?sslmode=require"

# Direct connection (used by `prisma migrate deploy`). Non-pooled host.
DIRECT_URL="postgresql://user:password@host:5432/commitment_tracker?sslmode=require"

# Auth.js secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-32-byte-random-hex-string"

# Web Push (PWA reminders). Generate with: node scripts/setup-push-env.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
CRON_SECRET=
